# This line should already be in your config somewhere (path might vary)
source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

typeset -A ZSH_HIGHLIGHT_STYLES

# Rosé Pine Color Palette Overrides
ZSH_HIGHLIGHT_STYLES[command]='fg=#f6c177,bold'               # Gold for commands
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#f6c177,bold'               # Gold for shell builtins
ZSH_HIGHLIGHT_STYLES[alias]='fg=#f6c177,bold'                 # Gold for aliases
ZSH_HIGHLIGHT_STYLES[path]='fg=#9ccfd8,underline'             # Foam (blue) for valid paths
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=#ebbcba'   # Rose for short flags (-h)
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=#ebbcba'   # Rose for long flags (--help)
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#c4a7e7' # Iris (purple) for strings
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#c4a7e7' # Iris (purple) for strings
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#eb6f92,bold'       # Love (red) for typos/errors
